          },
          "response": []
        },
        {
          "name": "Atualizar material",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Contrato Revisado\",\n  \"tipo\": \"PDF\",\n  \"url\": \"https://drive.google.com/file/contrato-v2\",\n  \"pendente\": false\n}",
