          "response": []
        },
        {
          "name": "Atualizar tarefa",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"texto\": \"Texto atualizado da tarefa\",\n  \"concluida\": true\n}",
              "options": {
                "raw": { "language": "json" }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/clientes/{{clienteId}}/tarefas/{{tarefaId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "clientes", "{{clienteId}}", "tarefas", "{{tarefaId}}"]
            },
            "description": "Atualiza uma tarefa. Todos os campos do body são opcionais."
          },
          "response": []
        },
        {
          "name": "Remover tarefa",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/clientes/{{clienteId}}/tarefas/{{tarefaId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "clientes", "{{clienteId}}", "tarefas", "{{tarefaId}}"]
            },
            "description": "Remove uma tarefa. Retorna 204 em caso de sucesso."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Observações",
      "item": [
        {
          "name": "Buscar observação da tarefa",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/clientes/{{clienteId}}/tarefas/{{tarefaId}}/observacao",
              "host": ["{{baseUrl}}"],
              "path": ["api", "clientes", "{{clienteId}}", "tarefas", "{{tarefaId}}", "observacao"]
            },
            "description": "Retorna a observação de uma tarefa."
          },
          "response": []
        },
        {
          "name": "Criar ou atualizar observação (upsert)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"observacao\": \"Cliente solicitou revisão do prazo de entrega\"\n}",
              "options": {
                "raw": { "language": "json" }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/clientes/{{clienteId}}/tarefas/{{tarefaId}}/observacao",
              "host": ["{{baseUrl}}"],
              "path": ["api", "clientes", "{{clienteId}}", "tarefas", "{{tarefaId}}", "observacao"]
            },
            "description": "Cria ou atualiza a observação de uma tarefa (upsert). Campo obrigatório: `observacao`."
          },
          "response": []
        },
        {
          "name": "Remover observação",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/clientes/{{clienteId}}/tarefas/{{tarefaId}}/observacao",
              "host": ["{{baseUrl}}"],
              "path": ["api", "clientes", "{{clienteId}}", "tarefas", "{{tarefaId}}", "observacao"]
            },
            "description": "Remove a observação de uma tarefa. Retorna 204 em caso de sucesso."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Materiais",
      "item": [
        {
          "name": "Listar biblioteca do cliente",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/clientes/{{clienteId}}/biblioteca",
              "host": ["{{baseUrl}}"],
              "path": ["api", "clientes", "{{clienteId}}", "biblioteca"]
            },
            "description": "Lista todos os materiais da biblioteca do cliente."
          },
          "response": []
        },
        {
          "name": "Adicionar material à biblioteca",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Contrato de Prestação de Serviços\",\n  \"tipo\": \"PDF\",\n  \"url\": \"https://drive.google.com/file/exemplo\",\n  \"pendente\": false\n}",
              "options": {
                "raw": { "language": "json" }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/clientes/{{clienteId}}/biblioteca",
              "host": ["{{baseUrl}}"],
              "path": ["api", "clientes", "{{clienteId}}", "biblioteca"]
            },
            "description": "Adiciona um material à biblioteca do cliente. Campos obrigatórios: `nome`, `tipo`.\n\n`tipo`: `PDF` | `PNG` | `DOC` | `XLS` | `LINK` | `VIDEO`"
          },
          "response": []
        },
        {
          "name": "Adicionar material à fase",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nome\": \"Apresentação de Resultados\",\n  \"tipo\": \"PDF\",\n  \"url\": \"https://drive.google.com/file/apresentacao\",\n  \"pendente\": true\n}",
              "options": {
                "raw": { "language": "json" }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/clientes/{{clienteId}}/fases/{{faseId}}/materiais",
