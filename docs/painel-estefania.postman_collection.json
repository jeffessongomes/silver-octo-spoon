              "raw": "{{baseUrl}}/api/clientes/{{clienteId}}/materiais/{{materialId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "clientes", "{{clienteId}}", "materiais", "{{materialId}}"]
