# Servidor
PORT=3000
NODE_ENV=development

# Banco de dados
DATABASE_URL=./data/painel.db

# Documentação Swagger (defina como false para desabilitar /api-docs em produção)
SWAGGER_ENABLED=true

# CORS: origins permitidas separadas por virgula (ex: http://localhost:5173,https://app.exemplo.com)
CORS_ORIGIN=
